{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "requityapp.com"
        }
      ],
      "destination": "https://www.requityapp.com/:path*",
      "permanent": true
    },
    {
      "source": "/auth",
      "destination": "/agent/login.html",
      "permanent": true
    },
    {
      "source": "/auth/:path*",
      "destination": "/agent/login.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/client/index.html"
    },
    {
      "source": "/:slug([^/]*-requityapp-relational-assessment)",
      "destination": "/client/assessment.html"
    }
  ]
}
