# REQUITY backend environment variables
# Copy this file to `.env` (local) and configure the same keys in Vercel.
# Never commit the real `.env` file.

# --- Supabase ---
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=
# Public anon key (safe for the browser / client-side calls).
SUPABASE_ANON_KEY=
# Service role key (server-side ONLY — full DB access, never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=

# --- Brevo (transactional email) ---
# Required for LIVE sending. When missing, email runs in test mode (logged only)
# and assessment/match flows still succeed (emailStatus: "skipped").
BREVO_API_KEY=
# Optional sender overrides (project-approved defaults are used when unset).
BREVO_SENDER_EMAIL=hello@requityapp.com
BREVO_SENDER_NAME=REQUITY
# Optional reviewer/admin fallback recipient for notifications with no assigned
# agent (e.g. a direct/reviewer-queue client completing the assessment).
# Either name works; REQUITY_REVIEW_EMAIL takes precedence.
REQUITY_REVIEW_EMAIL=
ADMIN_NOTIFICATION_EMAIL=

# --- Frontend / Vercel ---
# Public URL of the deployed frontend (used in email links and redirects).
# In production set this to https://requity-second-iteration.vercel.app
VERCEL_FRONTEND_URL=http://localhost:3000

# --- Stripe (one-time $50 agent platform access fee) ---
# Use TEST keys (sk_test_/pk_test_) until all QA passes, then switch to live.
# The secret key and webhook secret are server-side ONLY, never in the browser.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Webhook endpoint signing secret. Production: from the Stripe Dashboard
# webhook endpoint. Local: from `stripe listen` (never reuse the CLI value in
# Vercel Production).
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# The one-time $50 Price ID (create a $50 one-time Price in Stripe first).
STRIPE_AGENT_ACCESS_PRICE_ID=price_replace_me
# Public site origin used for Stripe success/cancel URLs.
PUBLIC_SITE_URL=https://www.requityapp.com
