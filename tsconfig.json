{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["api/**/*.ts", "backend/lib/**/*.ts", "backend/emails/**/*.ts", "backend/scripts/**/*.ts"],
  "exclude": ["node_modules", "**/node_modules", "backend/src/**/*.legacy.ts"]
}
