# REQUITY platform environment variables (Vercel project root)
#
# HOW TO USE
#   - Local dev:  copy this file to `.env` and fill in real values.
#   - Vercel:     add the SAME keys in Project → Settings → Environment Variables.
#   - Full walkthrough: see SETUP_SUPABASE_VERCEL.md.
#
# SAFETY
#   - NEVER commit a real `.env`. (It is already covered by .gitignore.)
#   - The SERVICE ROLE key and BREVO key are SECRETS — server-side only.
#     They must NEVER appear in frontend/shared/config.js or any NEXT_PUBLIC_* var.

# ============================================================================
# Server-side only (used by /api routes — NEVER exposed to the browser)
# ============================================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. If omitted, transactional email runs in TEST MODE (logged, not sent).
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# Required in production. Used for CORS origin + building shareable links.
VERCEL_FRONTEND_URL=

# Vercel sets NODE_ENV=production automatically on deploy. When production,
# protected API routes reject requests without a valid auth token (no demo).
# NODE_ENV=development

# ============================================================================
# Public (safe to expose to the browser) — used for browser Supabase Auth and
# as a local demo data fallback. These mirror the server values above.
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: base URL of the secure API, e.g. "/api" (same origin) or full URL.
NEXT_PUBLIC_API_BASE_URL=
