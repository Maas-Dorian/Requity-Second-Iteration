{
  "name": "requity-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "REQUITY platform: static frontend + secure Vercel API routes over Supabase.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check:dashes": "node scripts/check-no-cross-dashes.js",
    "check:domain": "node scripts/check-no-old-domain.js",
    "check:assessment-order": "node scripts/qa-assessment-order.cjs",
    "build": "node scripts/check-no-cross-dashes.js && node scripts/check-no-old-domain.js && node scripts/qa-assessment-order.cjs && node scripts/generate-config.js && tsc --noEmit",
    "seed:internal-users": "tsx backend/scripts/seed-internal-users.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/analytics": "^2.0.1",
    "qrcode": "^1.5.4",
    "stripe": "^22.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/node": "^3.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0"
  }
}
